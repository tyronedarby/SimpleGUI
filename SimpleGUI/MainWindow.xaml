<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SimpleGUI"
    Title="Simple WinUI App">

    <StackPanel 
        Padding="30"
        Spacing="15">

        <!-- TextBox Control -->
        <TextBox 
            x:Name="NameInput"
            Header="Enter your name"
            PlaceholderText="Name"/>


        <!-- ComboBox Control -->
        <ComboBox
            x:Name="CourseSelection"
            Header="Select your course">

            <ComboBoxItem Content="Computer Science"/>
            <ComboBoxItem Content="Information Technology"/>
            <ComboBoxItem Content="Engineering"/>

        </ComboBox>


        <!-- CheckBox Control -->
        <CheckBox
            x:Name="AgreeCheck"
            Content="I agree to continue"/>


        <!-- Button Control -->
        <Button
            Content="Submit"
            Click="Submit_Click"/>


        <!-- Output Text -->
        <TextBlock
            x:Name="ResultText"
            FontSize="18"/>

    </StackPanel>

</Window>
